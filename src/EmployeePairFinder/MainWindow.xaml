<Window x:Class="EmployeePairFinder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Employee Pair Finder"
        Height="650" Width="950"
        MinHeight="480" MinWidth="680"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Title -->
            <RowDefinition Height="Auto"/>  <!-- Controls -->
            <RowDefinition Height="Auto"/>  <!-- Loading bar -->
            <RowDefinition Height="Auto"/>  <!-- Error panel -->
            <RowDefinition Height="Auto"/>  <!-- Warnings panel -->
            <RowDefinition Height="Auto"/>  <!-- Result summary -->
            <RowDefinition Height="*"/>     <!-- DataGrid -->
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Employee Pair Finder"
                   FontSize="18" FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <!-- Control bar: Browse | File path | Date format | Load -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Browse..."
                    Command="{Binding BrowseCommand}"
                    Padding="10,4" Margin="0,0,6,0"
                    ToolTip="Select a CSV file"/>

            <TextBox Grid.Column="1"
                     Text="{Binding FilePath, Mode=OneWay}"
                     IsReadOnly="True"
                     Padding="4,4"
                     VerticalContentAlignment="Center"
                     ToolTip="{Binding FilePath}"/>

            <!-- Date format preference -->
            <Border Grid.Column="2"
                    BorderBrush="Gray" BorderThickness="1"
                    CornerRadius="2" Padding="8,4"
                    Margin="8,0">
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Date Format" FontSize="10" Foreground="Gray" Margin="0,0,0,2"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="European  DD/MM"
                                     IsChecked="{Binding IsEuropeanFormat, Mode=TwoWay}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,12,0"
                                     ToolTip="03/05 = 3rd May (default)"/>
                        <RadioButton Content="American  MM/DD"
                                     IsChecked="{Binding IsAmericanFormat, Mode=TwoWay}"
                                     VerticalAlignment="Center"
                                     ToolTip="03/05 = March 5th"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Button Grid.Column="3"
                    Content="Load Data"
                    Command="{Binding LoadCommand}"
                    Padding="10,4"
                    ToolTip="Parse the file and find the longest-working pair"/>
        </Grid>

        <!-- Thin indeterminate progress bar while loading -->
        <ProgressBar Grid.Row="2"
                     Height="4"
                     IsIndeterminate="True"
                     Margin="0,0,0,6"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>

        <!-- Error panel — red border, collapses when ErrorMessage is empty -->
        <Border Grid.Row="3"
                Background="#FFEEEE"
                BorderBrush="#CC0000" BorderThickness="1"
                Padding="8,5" Margin="0,0,0,4"
                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVis}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="DarkRed"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Warnings panel — collapsible expander, collapses when no warnings -->
        <Expander Grid.Row="4"
                  Header="{Binding WarningsSummary}"
                  Margin="0,0,0,4"
                  Visibility="{Binding HasWarnings, Converter={StaticResource BoolToVis}}">
            <Border Background="#FFFBE6" BorderBrush="Goldenrod" BorderThickness="1" Padding="8,4">
                <ScrollViewer MaxHeight="100" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Warnings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           FontSize="12"
                                           Margin="0,1"
                                           TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Expander>

        <!-- Result summary — visible whenever the text is non-empty (covers "no pair found" too) -->
        <TextBlock Grid.Row="5"
                   Text="{Binding ResultSummary}"
                   FontWeight="SemiBold"
                   FontSize="13"
                   Margin="0,0,0,6"
                   Visibility="{Binding ResultSummary, Converter={StaticResource StringToVis}}"/>

        <!-- DataGrid area -->
        <Grid Grid.Row="6">

            <!-- Empty-state hint shown before any file is loaded -->
            <TextBlock Text="Browse and load a CSV file to see results."
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="Gray"
                       FontSize="13"
                       Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVis}}"/>

            <!--
                Results DataGrid.
                AutoGenerateColumns=False keeps columns explicit.
                Row virtualisation handles large files without lag.
            -->
            <DataGrid ItemsSource="{Binding PairResults}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      SelectionMode="Single"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      EnableRowVirtualization="True"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Employee ID #1" Binding="{Binding EmpId1}"    Width="*" MinWidth="130"/>
                    <DataGridTextColumn Header="Employee ID #2" Binding="{Binding EmpId2}"    Width="*" MinWidth="130"/>
                    <DataGridTextColumn Header="Project ID"     Binding="{Binding ProjectId}" Width="*" MinWidth="110"/>
                    <DataGridTextColumn Header="Days Worked Together" Binding="{Binding DaysWorked}" Width="*" MinWidth="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

    </Grid>
</Window>
