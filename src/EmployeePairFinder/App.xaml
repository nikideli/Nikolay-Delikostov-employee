<Application x:Class="EmployeePairFinder.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:EmployeePairFinder.Converters">
    <!--
        No StartupUri — the main window is created programmatically in App.xaml.cs
        so that constructor-injected dependencies can be supplied via the DI container.
    -->
    <Application.Resources>
        <!-- Shared converters registered once at application level -->
        <conv:StringToVisibilityConverter x:Key="StringToVis"/>
        <BooleanToVisibilityConverter     x:Key="BoolToVis"/>
    </Application.Resources>
</Application>
